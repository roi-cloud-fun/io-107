# IO-107 SDLC Pipeline — lab_env_student / terraform.tfvars.example
#
# Copy this to terraform.tfvars and fill in the values.
# terraform.tfvars is gitignored.

aws_region = "us-east-1"

# Short identifier for whoever is running these labs. Lowercase, 1-16 chars.
# For LTF smoke tests, use something like "ltf-smoke" or "ltf-${TIMESTAMP}".
student_id = "REPLACE-ME"

vpc_cidr = "10.20.0.0/16"

# Optional: pin a specific suffix appended to every resource name.
# Leave commented out for a random 6-char suffix per `terraform apply`
# (recommended -- guarantees no collisions with leftovers from prior runs).
# Set this when you need reproducible names (e.g. an LTF test that expects
# a fixed cluster name across teardown/rebuild cycles).
# name_suffix = ""

# Toggle individual labs (default: all enabled)
# enable_lab1 = true
# enable_lab2 = true
# enable_lab3 = true
# enable_lab4 = true

